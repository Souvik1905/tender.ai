# Server configuration
PORT=5000
NODE_ENV=development
# Database configuration
MONGODB_URI=mongodb://127.0.0.1:27017/tender-ai
# Security configuration
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d
# Scraper configuration
# Set to 'true' to run scrapers in simulation mode (using realistic mock tenders)
# Set to 'false' to trigger actual Puppeteer scraping of official websites
SCRAPER_SIMULATION_MODE=true
# Schedule for the scraper (cron format). Default: daily at 2:00 AM
SCRAPER_CRON_SCHEDULE="0 2 * * *"
# Notification keys (Simulated for local dev)
SENDGRID_API_KEY=your_sendgrid_key_here
FROM_EMAIL=alerts@tender.ai
# Apify Configuration
APIFY_TOKEN=your_apify_api_token_here
APIFY_GEM_ACTOR_ID=krawlify/gem-portal-scraper
